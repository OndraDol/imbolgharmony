---
import type { Puppy } from '../data/puppies';

interface Props {
  puppy: Puppy;
  photoSrc?: string;
}
const { puppy, photoSrc } = Astro.props;
const bgColor = puppy.gender === 'girl' ? 'var(--pink-soft)' : 'var(--blue-soft)';
const badgeColor = puppy.gender === 'girl' ? '#9a4a5a' : '#4a5a7a';
---
<div class="puppy-card">
  <div class="puppy-photo" style={`background: ${bgColor}`}>
    {photoSrc
      ? <img src={photoSrc} alt={puppy.name} loading="lazy" decoding="async" />
      : <span class="puppy-emoji">{puppy.gender === 'girl' ? '🩷' : '💙'}</span>
    }
  </div>
  <div class="puppy-info">
    <div class="puppy-name">{puppy.name} <span class="puppy-nick">({puppy.nickname})</span></div>
    <div class="puppy-meaning">{puppy.meaning} {puppy.emoji}</div>
    <p class="puppy-personality">{puppy.personality}</p>
    <span class="puppy-badge" style={`background: ${bgColor}; color: ${badgeColor}`}>
      {puppy.badge} {puppy.status === 'home' ? '💞' : ''}
    </span>
  </div>
</div>

<style>
  .puppy-card {
    min-width: 170px;
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(90,62,43,0.08);
    scroll-snap-align: start;
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .puppy-card:hover { transform: translateY(-3px); }
  .puppy-photo {
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .puppy-photo img { width: 100%; height: 100%; object-fit: cover; }
  .puppy-emoji { font-size: 32px; }
  .puppy-info { padding: 12px 14px 16px; text-align: center; }
  .puppy-name { font-size: 15px; color: var(--brown); font-weight: bold; margin-bottom: 2px; }
  .puppy-nick { font-size: 12px; color: var(--text-light); font-weight: normal; }
  .puppy-meaning { font-size: 11px; color: var(--text-light); font-style: italic; margin-bottom: 6px; }
  .puppy-personality { font-size: 11px; color: var(--text); line-height: 1.5; margin-bottom: 8px; }
  .puppy-badge {
    display: inline-block;
    font-size: 9px;
    padding: 3px 10px;
    border-radius: 10px;
    letter-spacing: 0.5px;
    font-weight: bold;
  }
</style>
